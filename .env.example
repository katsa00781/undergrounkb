# EmailJS konfiguráció (opcionális)
# Ha be akarod állítani az automatikus email küldést:

# 1. Regisztrálj az EmailJS-re: https://www.emailjs.com/
# 2. Hozz létre egy service-t és template-et
# 3. Töltsd ki az alábbi értékeket:

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

# Supabase konfiguráció (kötelező)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Polar Flow integráció (opcionális)
# 1. Regisztrálj a Polar AccessLink admin felületén: https://admin.polaraccesslink.com
# 2. Állítsd be a redirect URI-t (pl. https://your-domain.com/polar/callback)
# 3. CSAK a publikus client_id és redirect_uri kerül ide. A client_secret-et NE ide,
#    hanem Supabase Edge Function secret-ként add meg:
#    supabase secrets set POLAR_CLIENT_ID=... POLAR_CLIENT_SECRET=... POLAR_REDIRECT_URI=...
VITE_POLAR_CLIENT_ID=your_polar_client_id
VITE_POLAR_REDIRECT_URI=https://your-domain.com/polar/callback
